# GCP Core
PROJECT_ID=your-project-id
LOCATION=us-central1

# Service Accounts
SERVICE_ACCOUNT_PIPELINE=pipeline-runner@your-project-id.iam.gserviceaccount.com
SERVICE_ACCOUNT_GITHUB=github-actions-cd-sa@your-project-id.iam.gserviceaccount.com

# Github details for Workload Identity
GITHUB_REPO=your-github-username/your-repo-name

# Legacy / Old Project IDs
LEGACY_PROJECT_ID=your-legacy-project-id
DEFAULT_DATASET_URL=gs://your-legacy-project-id-client-loras/datasets/user123.zip

# External LoRA references
LORA_URL_SHIBARI=https://civitai.com/api/download/models/your-lora-id
LORA_URL_BDSM=https://huggingface.co/youruser/your-model/resolve/main/your-file.safetensors

